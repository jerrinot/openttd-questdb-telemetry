{
  "formatName": "dexie",
  "formatVersion": 1,
  "data": {
    "databaseName": "web-console",
    "databaseVersion": 9,
    "tables": [
      {
        "name": "buffers",
        "schema": "++id,label,position,archived,archivedAt",
